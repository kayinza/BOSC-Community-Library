{
  "name": "bosc-community-library",
  "version": "1.0.0",
  "description": "A professional open source library designed for public sector transparency and community collaboration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:full": "npm run test:coverage && npm run lint && npm run type-check",
    "test:a11y": "jest --testPathPattern=accessibility",
    "test:security": "npm audit && jest --testPathPattern=security",
    "lint": "eslint src/**/*.{ts,tsx} --fix",
    "lint:check": "eslint src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src/**/*.{ts,tsx,json,md}",
    "format:check": "prettier --check src/**/*.{ts,tsx,json,md}",
    "prepare": "husky install",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "open-source",
    "public-sector",
    "government",
    "transparency",
    "community",
    "accessibility",
    "civic-tech"
  ],
  "author": "BOSC Community Library Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kayinza/BOSC-Community-Library.git"
  },
  "bugs": {
    "url": "https://github.com/kayinza/BOSC-Community-Library/issues"
  },
  "homepage": "https://github.com/kayinza/BOSC-Community-Library#readme",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.0",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "eslint": "^8.37.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-accessibility": "^3.0.0",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "prettier": "^2.8.7",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.2"
  },
  "dependencies": {
    "axios": "^1.3.4",
    "lodash": "^4.17.21"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}